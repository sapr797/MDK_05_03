## 2. Особенности тестирования инкапсуляции

### 2.1 Проблема: скрытое состояние

Инкапсуляция скрывает внутреннее состояние объекта. Это хорошо для дизайна, но создаёт трудности для тестирования.

```python
class BankAccount:
    def __init__(self):
        self._balance = 0      # Защищённый атрибут
        self.__pin = "0000"    # Приватный атрибут (name mangling)
    
    def deposit(self, amount):
        self._balance += amount
    
    def get_balance(self):
        return self._balance
2.2 Подходы к тестированию инкапсуляции
python
# Подход 1: Тестирование через публичный интерфейс (рекомендуется)
def test_balance_via_public_methods():
    account = BankAccount()
    account.deposit(100)
    assert account.get_balance() == 100

# Подход 2: Доступ к защищённым атрибутам (для отладки)
def test_balance_via_protected():
    account = BankAccount()
    account._balance = 500  # Не рекомендуется, но возможно
    assert account.get_balance() == 500

# Подход 3: Доступ к приватным атрибутам через name mangling (не рекомендуется)
def test_pin_via_private():
    account = BankAccount()
    # Имя изменено на _BankAccount__pin
    assert account._BankAccount__pin == "0000"
2.3 Тестирование getter/setter
python
class User:
    def __init__(self, name: str):
        self._name = name
        self._age = 0
    
    @property
    def name(self) -> str:
        return self._name
    
    @property
    def age(self) -> int:
        return self._age
    
    @age.setter
    def age(self, value: int):
        if not 0 <= value <= 150:
            raise ValueError("Invalid age")
        self._age = value

# Тесты
def test_name_getter():
    user = User("Alice")
    assert user.name == "Alice"

def test_age_setter_valid():
    user = User("Bob")
    user.age = 25
    assert user.age == 25

def test_age_setter_invalid():
    user = User("Charlie")
    with pytest.raises(ValueError, match="Invalid age"):
        user.age = 200
