3.2 Стратегия тестирования наследования
python
class Vehicle:
    def __init__(self, brand: str, speed: int):
        self.brand = brand
        self.speed = speed
    
    def move(self) -> str:
        return f"Vehicle {self.brand} is moving at {self.speed} km/h"
    
    def get_max_speed(self) -> int:
        return self.speed


class Car(Vehicle):
    def __init__(self, brand: str, speed: int, doors: int):
        super().__init__(brand, speed)
        self.doors = doors
    
    def move(self) -> str:
        return f"Car {self.brand} is driving at {self.speed} km/h"
    
    def honk(self) -> str:
        return "Beep beep!"


# === СТРАТЕГИЯ 1: Тесты родительского класса ===
class TestVehicle:
    def test_vehicle_move(self):
        vehicle = Vehicle("Generic", 100)
        assert "moving at 100 km/h" in vehicle.move()
    
    def test_vehicle_get_max_speed(self):
        vehicle = Vehicle("Generic", 100)
        assert vehicle.get_max_speed() == 100


# === СТРАТЕГИЯ 2: Базовый тест для иерархии ===
class BaseVehicleTest:
    """Базовый класс для тестирования всех транспортных средств."""
    
    def create_vehicle(self) -> Vehicle:
        raise NotImplementedError
    
    def test_move_returns_string(self):
        vehicle = self.create_vehicle()
        result = vehicle.move()
        assert isinstance(result, str)
        assert len(result) > 0
    
    def test_get_max_speed_returns_int(self):
        vehicle = self.create_vehicle()
        assert isinstance(vehicle.get_max_speed(), int)


# === СТРАТЕГИЯ 3: Тесты дочернего класса (свои + унаследованные) ===
class TestCar(BaseVehicleTest):
    def create_vehicle(self) -> Vehicle:
        return Car("Toyota", 180, 4)
    
    # Новые тесты для Car
    def test_car_honk(self):
        car = Car("Honda", 200, 2)
        assert car.honk() == "Beep beep!"
    
    def test_car_doors(self):
        car = Car("Ford", 150, 5)
        assert car.doors == 5
    
    # Проверка полиморфного поведения
    def test_car_move_override(self):
        car = Car("BMW", 250, 4)
        assert "driving" in car.move()
    
    # Тест LSP: Car должен вести себя как Vehicle
    def test_car_lsp_compliance(self):
        vehicle: Vehicle = Car("Audi", 220, 4)
        assert isinstance(vehicle.move(), str)
        assert vehicle.get_max_speed() == 220
4. Особенности тестирования полиморфизма
4.1 Тестирование полиморфного поведения
python
from abc import ABC, abstractmethod

class PaymentProcessor(ABC):
    @abstractmethod
    def process(self, amount: float) -> dict:
        pass
    
    @abstractmethod
    def get_fee(self, amount: float) -> float:
        pass


class CreditCardProcessor(PaymentProcessor):
    def process(self, amount: float) -> dict:
        return {"status": "success", "method": "credit_card", "fee": self.get_fee(amount)}
    
    def get_fee(self, amount: float) -> float:
        return amount * 0.025  # 2.5%


class PayPalProcessor(PaymentProcessor):
    def process(self, amount: float) -> dict:
        return {"status": "success", "method": "paypal", "fee": self.get_fee(amount)}
    
    def get_fee(self, amount: float) -> float:
        return amount * 0.035  # 3.5%


# === ПОЛИМОРФНЫЕ ТЕСТЫ ===
class BasePaymentProcessorTest:
    """Базовые полиморфные тесты для всех процессоров."""
    
    def create_processor(self) -> PaymentProcessor:
        raise NotImplementedError
    
    def test_process_returns_dict_with_status(self):
        processor = self.create_processor()
        result = processor.process(100)
        assert isinstance(result, dict)
        assert "status" in result
        assert result["status"] == "success"
    
    def test_get_fee_returns_positive_float(self):
        processor = self.create_processor()
        fee = processor.get_fee(100)
        assert isinstance(fee, float)
        assert fee > 0


class TestCreditCardProcessor(BasePaymentProcessorTest):
    def create_processor(self) -> PaymentProcessor:
        return CreditCardProcessor()
    
    def test_credit_card_specific_fee(self):
        processor = CreditCardProcessor()
        assert processor.get_fee(100) == 2.5
    
    def test_credit_card_method_in_result(self):
        processor = CreditCardProcessor()
        result = processor.process(100)
        assert result["method"] == "credit_card"


class TestPayPalProcessor(BasePaymentProcessorTest):
    def create_processor(self) -> PaymentProcessor:
        return PayPalProcessor()
    
    def test_paypal_specific_fee(self):
        processor = PayPalProcessor()
        assert processor.get_fee(100) == 3.5
    
    def test_paypal_method_in_result(self):
        processor = PayPalProcessor()
        result = processor.process(100)
        assert result["method"] == "paypal"
5. Тестирование взаимодействия объектов
5.1 Проблема: зависимые объекты
python
class EmailService:
    def send(self, to: str, subject: str, body: str) -> bool:
        # Реальная отправка email
        return True


class NotificationService:
    def __init__(self, email_service: EmailService):
        self.email_service = email_service
    
    def notify_user(self, user_email: str, message: str):
        return self.email_service.send(user_email, "Notification", message)
5.2 Решение: мокирование зависимостей
python
class TestNotificationService:
    def test_notify_user_sends_email(self):
        # Создаём мок EmailService
        mock_email = Mock(spec=EmailService)
        mock_email.send.return_value = True
        
        service = NotificationService(mock_email)
        result = service.notify_user("user@test.com", "Hello")
        
        assert result is True
        mock_email.send.assert_called_once_with(
            "user@test.com", "Notification", "Hello"
        )
    
    def test_notify_user_handles_failure(self):
        mock_email = Mock(spec=EmailService)
        mock_email.send.return_value = False
        
        service = NotificationService(mock_email)
        result = service.notify_user("user@test.com", "Hello")
        
        assert result is False
6. Типичные ошибки в ОО-коде и их тестирование
Ошибка	Описание	Как тестировать
Состояние гонки	Изменение объекта из нескольких потоков	Многопоточные тесты
Побочные эффекты	Метод меняет состояние, о котором тест не знает	Проверка состояния до/после
Нарушение LSP	Дочерний класс не заменяет родительский	Полиморфные тесты
Утечка памяти	Объекты не удаляются	Проверка ссылок
Неверная инициализация	Объект в некорректном состоянии после создания	Проверка инвариантов
